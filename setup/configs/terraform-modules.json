{
  "repo": {
    "description": "Private Terraform module library for the Nautilus IaC platform",
    "has_issues": true,
    "has_projects": false,
    "has_wiki": false,
    "delete_branch_on_merge": true,
    "allow_squash_merge": true,
    "allow_merge_commit": false,
    "allow_rebase_merge": false,
    "squash_merge_commit_title": "PR_TITLE",
    "squash_merge_commit_message": "PR_BODY"
  },
  "branch_protection": {
    "branch": "main",
    "required_status_checks": {
      "strict": true,
      "contexts": [
        "validate",
        "test"
      ]
    },
    "enforce_admins": true,
    "required_pull_request_reviews": {
      "dismiss_stale_reviews": true,
      "require_code_owner_reviews": true,
      "required_approving_review_count": 2,
      "require_last_push_approval": true
    },
    "restrictions": null,
    "allow_force_pushes": false,
    "allow_deletions": false,
    "required_conversation_resolution": true
  },
  "environments": [],
  "teams": [
    {
      "slug": "platform-infra",
      "permission": "maintain"
    }
  ],
  "labels": [
    {
      "name": "breaking-change",
      "color": "d73a4a",
      "description": "Introduces a breaking change requiring a major version bump"
    },
    {
      "name": "needs-migration-guide",
      "color": "e4e669",
      "description": "Breaking change — migration guide must be written before release"
    },
    {
      "name": "module:networking",
      "color": "0075ca",
      "description": "Affects the networking module"
    },
    {
      "name": "module:database",
      "color": "0075ca",
      "description": "Affects the database/postgres module"
    },
    {
      "name": "module:compute",
      "color": "0075ca",
      "description": "Affects the compute/aks module"
    },
    {
      "name": "module:governance",
      "color": "0075ca",
      "description": "Affects the governance/Azure Policy module"
    },
    {
      "name": "good-first-issue",
      "color": "7057ff",
      "description": "Good for new platform team members"
    },
    {
      "name": "bug",
      "color": "d73a4a",
      "description": "Something is not working as documented"
    },
    {
      "name": "module-request",
      "color": "a2eeef",
      "description": "Request for a new Terraform module"
    },
    {
      "name": "sku-request",
      "color": "a2eeef",
      "description": "Request to add a SKU to the approved list"
    }
  ],
  "templates": {
    "codeowners": "platform",
    "pull_request_template": true,
    "issue_templates": [
      "bug_report",
      "new_module",
      "sku_request"
    ]
  }
}
