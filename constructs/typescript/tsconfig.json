{
  "compilerOptions": {
    "target":           "ES2020",
    "lib":              ["ES2020"],
    "module":           "commonjs",
    "moduleResolution": "node",
    "declaration":      true,
    "declarationMap":   true,
    "sourceMap":        true,
    "outDir":           "lib",
    "rootDir":          "src",
    "strict":           true,
    "esModuleInterop":  true
  },
  "include": ["src"],
  "exclude": ["node_modules", "lib", "test"]
}
