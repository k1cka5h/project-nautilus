# ── Terraform ────────────────────────────────────────────────────────────────

# Local .terraform directories
.terraform/

# State files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Override files (used to override resources locally)
override.tf
override.tf.json
