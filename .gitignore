*_override.tf.json

# Transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Plan output files
*.tfplan
emergency.tfplan

# CLI configuration files
.terraformrc
terraform.rc

# CDKTF synthesized output
cdktf.out/

